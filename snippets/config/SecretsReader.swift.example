//  SecretsReader.swift.example  —  BYO-key runtime resolution (NO real secrets here)
//  ==================================================================================
//  Scaffolding for the NEW minimal-realtime-kit repo. Replaces the source app's
//  hardcoded literals in RealtimeManager.startConversation() (which MUST be stripped —
//  see research/05-config-keys-build.md) with a keyless, resolve-at-runtime path.
//
//  Resolution order (first non-empty wins; nil => UI prompts the user to paste a key,
//  the app NEVER crashes and a clean clone compiles):
//    1. In-app store (Keychain) set by a "paste your key" screen — best for shipping.
//    2. Generated Info.plist value surfaced from Config/Secrets.xcconfig via
//       INFOPLIST_KEY_<KEY> = $(<KEY>) — convenient for local dev.
//    3. Process environment (e.g. SIMCTL_CHILD_<KEY> on the simulator).
//
//  NOTHING below is a secret. The "<<" guard rejects un-filled placeholders.

import Foundation

enum Secrets {
    /// Direct BYO OpenAI key (transport A). nil when unset.
    static var openAIAPIKey: String? { resolve("OPENAI_API_KEY") }

    /// AIProxy partial key + service URL (transport B). These are NOT the OpenAI key.
    static var aiproxyPartialKey: String? { resolve("AIPROXY_PARTIAL_KEY") }
    static var aiproxyServiceURL: String? { resolve("AIPROXY_SERVICE_URL") }

    private static func resolve(_ key: String) -> String? {
        // 1) In-app Keychain (set via a paste-your-key UI). Cleanest for an open-source app.
        if let v = KeychainStore.string(forKey: key), isUsable(v) { return v }

        // 2) Generated Info.plist value from Config/Secrets.xcconfig.
        if let v = Bundle.main.object(forInfoDictionaryKey: key) as? String, isUsable(v) { return v }

        // 3) Process env — handy for the simulator (SIMCTL_CHILD_OPENAI_API_KEY=...).
        if let v = ProcessInfo.processInfo.environment[key], isUsable(v) { return v }

        return nil
    }

    /// Reject empty strings and un-filled "<<PASTE_YOUR_OWN>>" / "REPLACE_" placeholders.
    private static func isUsable(_ v: String) -> Bool {
        let t = v.trimmingCharacters(in: .whitespacesAndNewlines)
        return !t.isEmpty && !t.hasPrefix("<<") && !t.hasPrefix("REPLACE_")
    }
}

// Replace with a real Keychain wrapper (kSecClassGenericPassword), or delete tiers you don't use.
// Stub returns nil so this snippet compiles standalone.
private enum KeychainStore {
    static func string(forKey _: String) -> String? { nil }
}
